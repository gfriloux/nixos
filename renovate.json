{
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/.*\\.nix$/"],
      "matchStrings": ["image = \"(?<currentValue>.*?)\"; # renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)"],
      "datasourceTemplate": "{{datasource}}"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "pinDigests": true
    }
  ]
}
